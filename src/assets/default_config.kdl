config-paths {{
    config-path-home "/etc/nixos/home/home.nix"
    config-path-system "/etc/nixos/modules/packages.nix"
    path-nix-flake "/etc/nixos" // Hostname does not need to be specified
}}
config-markers {{
    marker-home "home.packages = with pkgs; ["
    marker-system "environment.systemPackages = with pkgs; ["
    marker-home-end "];"
    marker-system-end "];"
}}
config-security {{
    su-type "{}"
}}
